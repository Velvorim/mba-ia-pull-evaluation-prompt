# =============================================================================
# CONFIGURAÇÃO DO AMBIENTE - Desafio Pull, Otimização e Avaliação de Prompts
# =============================================================================
# 1. Copie este arquivo para .env:  cp .env.example .env   (Linux/Mac) ou copie manualmente no Windows
# 2. Preencha os valores abaixo. NUNCA commite o arquivo .env (ele já está no .gitignore)
# =============================================================================

# --- LangSmith (obrigatório para pull, push e evaluate) ---
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=sua_langsmith_api_key_aqui
# Nome legível do projeto no LangSmith (evite UUID; use um nome como abaixo)
# Ex.: bug-to-user-story-eval | prompt-optimization-challenge
LANGSMITH_PROJECT=bug-to-user-story-eval
# Opcional: limite de exemplos (vazio = todos os 15). Ex.: EVAL_MAX_EXAMPLES=5 para limitar
#EVAL_MAX_EXAMPLES=

# Seu username no LangSmith Hub (para push dos prompts). Ex: leonanluppi ou seu-usuario
# Como obter: https://smith.langchain.com → Settings → ou publique um prompt e veja o dono no URL
USERNAME_LANGSMITH_HUB=seu_username_langsmith

# --- Escolha UM provider de LLM ---

# Opção A: OpenAI (recomendado se tiver créditos; avaliação usa 10 exemplos)
# OPENAI_API_KEY: https://platform.openai.com/api-keys
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# EVAL_MODEL=gpt-4o
# OPENAI_API_KEY=sua_openai_api_key_aqui

# Opção B: Google Gemini (free: 10 req/min, 250 req/dia; avaliação usa todos os 15 + delay ~7s entre chamadas)
# GOOGLE_API_KEY: https://aistudio.google.com/app/apikey
# Para forçar mais exemplos (ex.: 15) use EVAL_MAX_EXAMPLES=15 (pode dar 429 no free tier)
LLM_PROVIDER=google
LLM_MODEL=gemini-3.1-flash-lite-preview
EVAL_MODEL=gemini-3.1-flash-lite-preview
GOOGLE_API_KEY=sua_google_api_key_aqui
